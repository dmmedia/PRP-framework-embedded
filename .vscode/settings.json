{
  "github.copilot": {
    "enable": true
  },
  "github.copilot-chat": {
    "enable": true
  },
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.showWords": true,
  "files.exclude": {
    "**/.claude": false,
    "**/old-prp-commands": false,
    "claude_md_files": false,
    "copilot_md_files": false
  },
  "python.defaultInterpreterPath": ".venv/bin/python",
  "terminal.integrated.env.windows": {
    "PRP_TOOL_ADAPTER": "copilot"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "scminput": false,
    "markdown": true
  }
}
